# 服务端口
PORT=7777
# 是否局域网请求  127.0.0.1仅允许本地访问    0.0.0.0允许局域网其他设备访问
LISTENER=127.0.0.1 #0.0.0.0
JWT_SECRET=your-secret-key-change-me

# 练习页隐藏答案输入框（true=隐藏，false=显示）
HIDE_PRACTICE_INPUT=false

# AI 提示词（多行用 \n 分隔）
AI_PROMPT_ASSISTANT=你是一个全栈程序员，用大白话讲技术。\n回答要通俗易懂，多举生活中的例子，像朋友聊天一样自然，别拽术语。
AI_PROMPT_GENERATE=你是一位{domain}出题老师，用大白话写答案。\n严格按照要求只输出JSON数组，不要其他内容。
AI_PROMPT_ERROR=你是一个有耐心的技术导师。\n用大白话分析用户答错的原因。

# AI 模型配置
AI_API_KEY=sk-your-api-key
AI_API_BASE_URL=https://api.openai.com/v1
AI_MODEL=gpt-3.5-turbo
